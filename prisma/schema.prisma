generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Config {
  id               Int      @id @default(autoincrement())
  tasaCambio       Float    @default(1)
  // Porcentaje de ganancia que se aplica por defecto sobre el costo de cada
  // producto (a menos que el producto tenga su propio margenPorcentaje).
  margenPorcentaje Float    @default(30)
  updatedAt        DateTime @updatedAt
}

model Product {
  id        String      @id @default(cuid())
  // Código de barras / SKU del sistema de la tienda física (Excel). Permite
  // reimportar el catálogo sin crear productos duplicados.
  codigo    String?     @unique
  nombre    String
  // Precio de COSTO (lo que paga la tienda). Nunca se muestra al cliente.
  costoUsd  Float
  // Margen específico de este producto, en porcentaje. Si es null, se usa
  // el margenPorcentaje general de Config.
  margenPorcentaje Float?
  categoria String
  imagenUrl String?
  activo    Boolean     @default(true)
  createdAt DateTime    @default(now())
  orderItems OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  clienteNombre   String
  clienteTelefono String
  direccion       String
  estado          String      @default("PENDIENTE_VERIFICACION")
  tasaCambio      Float
  totalUsd        Float?
  totalBs         Float?
  comprobanteUrl  String?
  notas           String?
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  cantidad   Int
  // Precio final (ya con margen + delivery) al momento del pedido, para que
  // si luego cambia el costo o el margen, los pedidos viejos no se alteren.
  precioUsd  Float
  disponible Boolean?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
}
