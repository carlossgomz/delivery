generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id               String      @id @default(cuid())
  codigo           String      @unique
  nombre           String
  // costoUsd y margenPorcentaje quedaron sin uso: el admin ahora carga
  // precioUsd directamente como precio final. Se dejan en el schema
  // para no perder datos históricos, pero ningún endpoint los lee ni escribe.
  costoUsd         Float?
  margenPorcentaje Float?      @default(30)
  precioUsd        Float       @default(0)
  categoria        String
  imagenUrl        String?
  activo           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  OrderItem        OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  // Estos tres campos se guardan siempre como "foto" del pedido (nombre,
  // teléfono, dirección en ese momento), tenga o no cuenta el cliente.
  // Así el historial no cambia si luego el cliente edita su perfil.
  clienteNombre   String
  clienteTelefono String
  direccion       String
  estado          String      @default("PENDIENTE_VERIFICACION")
  tasaCambio      Float
  totalUsd        Float?
  totalBs         Float?
  comprobanteUrl  String?
  notas           String?
  notaPago        String?
  createdAt       DateTime    @default(now())
  items           OrderItem[]

  // Opcional: si el pedido lo hizo un cliente con cuenta registrada, queda
  // enlazado aquí para poder mostrarle su historial de pedidos.
  clienteId       String?
  cliente         Cliente?    @relation(fields: [clienteId], references: [id])
}

// Cuenta simple de cliente: se registra con teléfono + contraseña para no
// tener que volver a escribir nombre/teléfono/dirección en cada pedido y
// para poder ver el historial de pedidos ya hechos.
model Cliente {
  id           String   @id @default(cuid())
  nombre       String
  telefono     String   @unique
  direccion    String
  passwordHash String
  createdAt    DateTime @default(now())
  orders       Order[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  cantidad   Int
  precioUsd  Float
  disponible Boolean?
  product    Product  @relation(fields: [productId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Config {
  id             Int      @id @default(autoincrement())
  tasaCambio     Float    @default(1)
  // Número que usa el botón "Llamar a la tienda" y el que se muestra en el
  // chat. Se edita desde el mismo panel donde se edita la tasa.
  telefonoTienda String?  @default("04266215863")
  updatedAt      DateTime @updatedAt
}

// Una conversación por cliente. El cliente no tiene cuenta ni login: se
// identifica con un id aleatorio que el navegador genera una sola vez y
// guarda en localStorage (igual que ya se hace con el carrito).
model Conversacion {
  id              String    @id @default(cuid())
  clienteId       String    @unique
  clienteNombre   String?
  clienteTelefono String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  mensajes        Mensaje[]
}

model Mensaje {
  id             String       @id @default(cuid())
  conversacionId String
  // "CLIENTE" o "TIENDA"
  remitente      String
  texto          String
  leido          Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
}
