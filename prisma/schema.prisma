generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id               String      @id @default(cuid())
  codigo           String      @unique
  nombre           String
  costoUsd         Float?
  margenPorcentaje Float?      @default(30)
  precioUsd        Float       @default(0)
  categoria        String
  imagenUrl        String?
  activo           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  OrderItem        OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  clienteNombre   String
  clienteTelefono String
  direccion       String
  estado          String      @default("PENDIENTE_VERIFICACION")
  tasaCambio      Float
  totalUsd        Float?
  totalBs         Float?
  comprobanteUrl  String?
  notas           String?
  notaPago        String?
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  cantidad   Int
  precioUsd  Float
  disponible Boolean?
  product    Product  @relation(fields: [productId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Config {
  id         Int      @id @default(autoincrement())
  tasaCambio Float    @default(1)
  updatedAt  DateTime @updatedAt
}
